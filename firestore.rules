rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function myUser() {
      return userDoc(request.auth.uid);
    }

    function isVerified() {
      return signedIn() && request.auth.token.email_verified == true;
    }

    function isApproved() {
      return isVerified() && myUser().data.isApproved == true;
    }

    function isAdmin() {
      return signedIn() && myUser().data.role == 'admin';
    }

    function isDriver() {
      return isApproved() && myUser().data.role == 'driver';
    }

    function isClient() {
      return isApproved() && myUser().data.role == 'client';
    }

    function isStore() {
      return isApproved() && myUser().data.role == 'store';
    }

    function orderParticipant(orderId) {
      let order = get(/databases/$(database)/documents/orders/$(orderId));
      return isApproved()
        && (
          order.data.clientId == request.auth.uid
          || order.data.driverId == request.auth.uid
          || order.data.storeId == request.auth.uid
        );
    }

    match /users/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role in ['client', 'driver', 'store']
        && request.resource.data.isApproved == false;

      allow read: if signedIn()
        && (request.auth.uid == uid || isAdmin() || isApproved());

      allow update: if signedIn() && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'fullName',
            'phoneNumber',
            'wilaya',
            'commune',
            'email',
            'isEmailVerified',
            'profilePhotoBase64',
            'storeType',
            'storeAddress',
            'storeDeliveryFee',
            'isAvailable',
            'fcmTokens',
            'fcmTokenUpdatedAt',
            'currentLocation',
            'locationUpdatedAt',
            'updatedAt'
          ]);

      allow update: if isAdmin();
      allow delete: if isAdmin();

      match /menu_items/{itemId} {
        allow read: if isApproved();
        allow create, update, delete: if isStore()
          && request.auth.uid == uid;
      }
    }

    match /{path=**}/menu_items/{itemId} {
      allow read: if isApproved();
    }

    match /orders/{orderId} {
      allow create: if isClient()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status in ['open', 'requested', 'storePending']
        && (
          request.resource.data.status == 'open'
          || request.resource.data.driverId is string
          || (
            request.resource.data.status == 'storePending'
            && request.resource.data.sourceType == 'store'
            && request.resource.data.storeId is string
          )
        );

      allow read: if isAdmin()
        || (isClient() && resource.data.clientId == request.auth.uid)
        || isDriver()
        || (isStore() && resource.data.storeId == request.auth.uid);

      allow update: if isClient()
        && resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && resource.data.status in ['open', 'bidding']
        && request.resource.data.status == 'accepted'
        && request.resource.data.driverId is string
        && request.resource.data.acceptedBidId is string
        && request.resource.data.acceptedBidAmount is number
        && exists(/databases/$(database)/documents/orders/$(orderId)/bids/$(request.resource.data.acceptedBidId))
        && get(/databases/$(database)/documents/orders/$(orderId)/bids/$(request.resource.data.acceptedBidId)).data.driverId == request.resource.data.driverId
        && get(/databases/$(database)/documents/orders/$(orderId)/bids/$(request.resource.data.acceptedBidId)).data.amount == request.resource.data.acceptedBidAmount
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'status',
            'driverId',
            'acceptedBidId',
            'acceptedBidAmount',
            'acceptedAt',
            'updatedAt'
          ]);

      allow update: if isClient()
        && resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && resource.data.status == 'priced'
        && request.resource.data.status == 'accepted'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'acceptedAt', 'updatedAt']);

      allow update: if isClient()
        && resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && resource.data.status == 'priced'
        && request.resource.data.status == 'rejected'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'rejectedAt', 'updatedAt']);

      allow update: if isClient()
        && resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && resource.data.status in ['open', 'bidding', 'requested', 'priced', 'storePending', 'storeDriverPending', 'storeDriverRejected']
        && request.resource.data.status == 'cancelled'
        && request.resource.data.cancelledBy == request.auth.uid
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'cancelReason', 'cancelledBy', 'cancelledAt', 'updatedAt']);

      allow update: if isClient()
        && resource.data.clientId == request.auth.uid
        && resource.data.status in ['delivered', 'rejected']
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['hiddenByClientIds', 'hiddenAt', 'updatedAt'])
        && request.auth.uid in request.resource.data.hiddenByClientIds;

      allow update: if isClient()
        && resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && resource.data.status in ['accepted', 'inProgress']
        && request.resource.data.status == 'delivered'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'deliveredAt', 'updatedAt']);

      allow update: if isDriver()
        && resource.data.status in ['open', 'bidding']
        && request.resource.data.status == 'bidding'
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'bidCount', 'updatedAt']);

      allow update: if isDriver()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == resource.data.driverId
        && resource.data.status in ['requested', 'rejected']
        && request.resource.data.status == 'priced'
        && request.resource.data.acceptedBidAmount is number
        && request.resource.data.acceptedBidAmount > 0
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'acceptedBidAmount', 'pricedAt', 'updatedAt']);

      allow update: if isDriver()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == resource.data.driverId
        && resource.data.status == 'accepted'
        && request.resource.data.status == 'inProgress'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'startedAt', 'updatedAt']);

      allow update: if isDriver()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == resource.data.driverId
        && resource.data.status == 'storeDriverPending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'acceptedAt', 'driverRespondedAt', 'updatedAt']);

      allow update: if isDriver()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == resource.data.driverId
        && resource.data.status == 'storeDriverPending'
        && request.resource.data.status == 'storeDriverRejected'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'driverRespondedAt', 'updatedAt']);

      allow update: if isDriver()
        && resource.data.driverId == request.auth.uid
        && request.resource.data.driverId == resource.data.driverId
        && resource.data.status == 'inProgress'
        && request.resource.data.status == 'delivered'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'deliveredAt', 'updatedAt']);

      allow update: if isStore()
        && resource.data.storeId == request.auth.uid
        && resource.data.status in ['storePending', 'storeDriverRejected']
        && request.resource.data.status == 'storeDriverPending'
        && request.resource.data.driverId is string
        && request.resource.data.acceptedBidAmount == resource.data.deliveryFee
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'status',
            'driverId',
            'acceptedBidAmount',
            'assignedByStoreAt',
            'driverRespondedAt',
            'updatedAt'
          ]);

      allow update: if isStore()
        && resource.data.storeId == request.auth.uid
        && resource.data.status == 'storePending'
        && request.resource.data.status == 'rejected'
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['status', 'rejectedByStoreAt', 'updatedAt']);

      allow delete: if isClient()
        && resource.data.clientId == request.auth.uid
        && resource.data.status in ['delivered', 'rejected', 'cancelled'];

      allow update, delete: if isAdmin();

      match /bids/{bidId} {
        allow create: if isDriver()
          && bidId == request.auth.uid
          && request.resource.data.driverId == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.keys().hasOnly([
            'driverId',
            'driverName',
            'driverRating',
            'amount',
            'status',
            'updatedAt',
            'createdAt'
          ]);

        allow read: if isAdmin()
          || isDriver()
          || (isClient()
            && get(/databases/$(database)/documents/orders/$(orderId)).data.clientId == request.auth.uid);

        allow update: if isClient()
          && get(/databases/$(database)/documents/orders/$(orderId)).data.clientId == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status in ['accepted', 'rejected']
          && request.resource.data.diff(resource.data)
            .affectedKeys()
            .hasOnly(['status', 'updatedAt']);

        allow update, delete: if isAdmin();
      }

      match /messages/{messageId} {
        allow read: if isAdmin() || orderParticipant(orderId);
        allow create: if orderParticipant(orderId)
          && get(/databases/$(database)/documents/orders/$(orderId)).data.status in ['accepted', 'inProgress']
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 800
          && request.resource.data.keys().hasOnly([
            'senderId',
            'senderName',
            'text',
            'createdAt'
          ]);
        allow delete: if isAdmin() || orderParticipant(orderId);
        allow update: if false;
      }
    }

    match /notifications/{notificationId} {
      allow create: if isApproved();
      allow read: if isApproved()
        && resource.data.userId == request.auth.uid;
      allow update: if isApproved()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly(['read', 'readAt']);
      allow delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if isApproved()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'open'
        && request.resource.data.type in ['support', 'report', 'payment'];

      allow read: if isAdmin()
        || (isApproved() && resource.data.createdBy == request.auth.uid);

      allow update: if isAdmin()
        && request.resource.data.diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'status',
            'adminNote',
            'adminReply',
            'adminRepliedAt',
            'updatedAt',
            'closedAt'
          ]);

      allow delete: if isAdmin();
    }

    match /driver_call_logs/{logId} {
      allow create: if isClient()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.driverId is string;
      allow read: if isAdmin()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /store_call_logs/{logId} {
      allow create: if isClient()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.storeId is string;
      allow read: if isAdmin()
        || (isStore() && resource.data.storeId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /app_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /app_releases/{releaseId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /site_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subscription_payments/{paymentId} {
      allow create: if isApproved()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.role in ['driver', 'store']
        && request.resource.data.status == 'pending'
        && request.resource.data.receiptBase64 is string
        && request.resource.data.receiptBase64.size() > 0;
      allow read: if isAdmin()
        || (isApproved() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /app_banners/{bannerId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /app_categories/{categoryId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /admin_logs/{logId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
